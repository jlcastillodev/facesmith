{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["src/*"],
      "@/components/*": ["src/components/*"],
      "@/lib/*": ["src/lib/*"],
      "@core/*": ["../../packages/core/src/*"]
    },
    "types": ["jest", "node", "@testing-library/jest-dom"],
    "verbatimModuleSyntax": false
  },
  "include": ["src", "__tests__", "astro.config.mjs"],
  "exclude": ["dist", "node_modules"]
}
