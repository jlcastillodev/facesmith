# Example environment file for FaceSmith
# Copy this to apps/site/.env.local and set your Worker URL
# Public site configuration
PUBLIC_FACESMITH_API_URL="https://<your-worker-subdomain>/api"

# Worker deployment variables
# AI_PROVIDER=cloudflare
# AI_ACCOUNT_ID=<your-account-id>
# AI_MODEL=@cf/black-forest-labs/flux-1-schnell
# ORIGIN_ALLOW=http://localhost:4321,https://yourdomain.com

# Secrets are managed with `wrangler secret put AI_TOKEN`
