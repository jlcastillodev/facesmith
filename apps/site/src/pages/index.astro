---
import '../styles/tailwind.css';
import ThemeToggle from '@/components/ThemeToggle';
import { PromptTuner } from '@/components/PromptTuner';
import { CATEGORIES } from '@/lib/prompts/categories';
---
<!DOCTYPE html>
<html lang="en" class="bg-surface text-foreground" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>FaceSmith — Forge your identity</title>
    <meta
      name="description"
      content="Open-source, IP-safe avatar generator starter with Astro, Tailwind, and TypeScript."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (() => {
        try {
          // Only apply stored theme, not system preference initially to avoid hydration mismatch
          const storedTheme = localStorage.getItem('facesmith.theme');
          const theme = storedTheme === 'dark' ? 'dark' : 'light';
          document.documentElement.dataset.theme = theme;
          document.body?.setAttribute('data-theme', theme);
          document.documentElement.classList.toggle('dark', theme === 'dark');
          document.body?.classList.toggle('dark', theme === 'dark');
        } catch (error) {
          console.warn('Unable to apply persisted theme', error);
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-foreground transition-colors dark:bg-surface-dark dark:text-foreground-dark">
    <header class="border-b border-slate-200 bg-white/90 backdrop-blur dark:border-slate-800 dark:bg-slate-900/90">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-6">
        <div>
          <h1 class="font-display text-2xl font-semibold text-slate-900 dark:text-slate-100">FaceSmith</h1>
          <p class="text-sm text-slate-600 dark:text-slate-300">
            Forge IP-safe AI avatars with confidence.
          </p>
        </div>
        <ThemeToggle client:load />
      </div>
    </header>
    <main class="mx-auto flex max-w-5xl flex-1 flex-col gap-10 px-4 py-10">
      <section class="flex flex-col gap-4">
        <h2 class="font-display text-xl text-slate-900 dark:text-slate-100">Prototype your avatar prompts</h2>
        <p class="text-slate-600 dark:text-slate-300">
          FaceSmith keeps prompts IP-safe by blocking trademarked entities and rewriting your inputs. Start experimenting
          with safe avatar directions before connecting your preferred AI engine.
        </p>
      </section>
      <PromptTuner client:load categories={CATEGORIES} />
      <div id="bulk" class="mt-4 hidden"></div>
      <section class="prose prose-slate dark:prose-invert">
        <h3>Why FaceSmith?</h3>
        <ul>
          <li>IP guardrails with blocklist enforcement and prompt rewriting.</li>
          <li>Production-ready stack: Astro, React islands, Tailwind, TypeScript.</li>
          <li>Tested with Jest and deployed automatically to GitHub Pages.</li>
        </ul>
      </section>
    </main>
    <footer class="border-t border-slate-200 bg-white py-6 text-center text-sm text-slate-500 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-400 w-full">
      <div class="mx-auto max-w-5xl px-4">
        Built with ❤️ for secure creativity. <a href="/docs">Read the docs</a>.
      </div>
    </footer>
    <script type="module">
      import { createElement } from 'react';
      import { createRoot } from 'react-dom/client';
      import DownloadAll from '../components/DownloadAll.tsx';
      import { downloadDataUrl } from '../lib/download.ts';

      const globalWindow = window;
      globalWindow.__zipItems = [];
      globalWindow.__downloadDataUrl = downloadDataUrl;

      const bulkContainer = document.getElementById('bulk');
      let bulkRoot = null;
      let activeToast = null;
      let dismissTimer = 0;

      const renderBulkButton = () => {
        if (!bulkContainer) {
          return;
        }

        if (!globalWindow.__zipItems.length) {
          bulkContainer.classList.add('hidden');
          if (bulkRoot) {
            bulkRoot.unmount();
            bulkRoot = null;
          }
          return;
        }

        bulkContainer.classList.remove('hidden');
        if (!bulkRoot) {
          bulkRoot = createRoot(bulkContainer);
        }

        bulkRoot.render(createElement(DownloadAll, { items: globalWindow.__zipItems }));
      };

      const showToast = (message) => {
        if (!document.body) {
          return;
        }

        if (activeToast) {
          activeToast.remove();
        }
        if (dismissTimer) {
          clearTimeout(dismissTimer);
          dismissTimer = 0;
        }

        const toast = document.createElement('div');
        toast.textContent = message;
        toast.className = 'pointer-events-none fixed top-4 right-4 z-50 rounded-md bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow-lg transition-opacity duration-300 opacity-0';
        document.body.appendChild(toast);

        requestAnimationFrame(() => {
          toast.classList.remove('opacity-0');
          toast.classList.add('opacity-100');
        });

        dismissTimer = window.setTimeout(() => {
          toast.classList.remove('opacity-100');
          toast.classList.add('opacity-0');
          window.setTimeout(() => {
            toast.remove();
          }, 300);
        }, 2400);

        activeToast = toast;
      };

      window.addEventListener('facesmith:avatars-generated', (event) => {
        const detail = event.detail || {};
        const avatars = Array.isArray(detail.avatars) ? detail.avatars : [];

        globalWindow.__zipItems = avatars
          .map((item, index) => ({
            filename:
              item && typeof item.filename === 'string' && item.filename
                ? item.filename
                : `avatar-${index + 1}.png`,
            dataUrl: item && typeof item.dataUrl === 'string' ? item.dataUrl : '',
          }))
          .filter((item) => Boolean(item.dataUrl));

        renderBulkButton();

        if (globalWindow.__zipItems.length > 0) {
          const count = globalWindow.__zipItems.length;
          showToast(`Generated ${count} avatar${count === 1 ? '' : 's'}`);
        }
      });
    </script>
  </body>
</html>
