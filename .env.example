# Example environment file for FaceSmith
# Copy this to apps/site/.env.local and set your Worker URL
# Facesmith Configuration
PUBLIC_FACESMITH_API_URL=""

# Cloudflare Worker Configuration (for worker deployment)
# You need to set these in the Cloudflare Worker dashboard or via wrangler secrets
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_AI_API_TOKEN=""

# Optional: AI Model Configuration
CLOUDFLARE_AI_MODEL="@cf/black-forest-labs/flux-1-schnell"

# Development settings
NODE_ENV="development"